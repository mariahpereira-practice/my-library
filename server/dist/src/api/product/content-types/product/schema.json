{
    "kind": "collectionType",
    "collectionName": "products",
    "info": {
        "singularName": "product",
        "pluralName": "products",
        "displayName": "Produtos"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "description": {
            "type": "text"
        },
        "price": {
            "type": "decimal"
        },
        "stock": {
            "type": "integer"
        },
        "image": {
            "type": "media",
            "multiple": false,
            "allowedTypes": [
                "images",
                "files",
                "videos",
                "audios"
            ]
        },
        "categorias": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::category.category"
        },
        "autor": {
            "type": "string",
            "required": true
        }
    }
}
